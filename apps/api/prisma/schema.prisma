generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ConversionMetric {
  id                String   @id @default(cuid())
  clientIdHash      String?  @map("client_id_hash")
  inputFormat       String   @map("input_format")
  outputFormat      String   @map("output_format")
  inputSizeBytes    Int      @map("input_size_bytes")
  outputSizeBytes   Int?     @map("output_size_bytes")
  processingTimeMs  Int?     @map("processing_time_ms")
  success           Boolean  @default(true)
  errorMessage      String?  @map("error_message")
  conversionOptions Json?    @map("conversion_options")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([clientIdHash])
  @@index([createdAt])
  @@map("conversion_metrics")
}

model ErrorSubmission {
  id               String   @id @default(cuid())
  clientIdHash     String?  @map("client_id_hash")
  originalFilename String   @map("original_filename")
  fileSizeBytes    Int      @map("file_size_bytes")
  svgContent       String   @map("svg_content")
  errorMessage     String   @map("error_message")
  errorType        String   @map("error_type")
  classification   String?
  matchedPatterns  Json?    @map("matched_patterns")
  patternLocations Json?    @map("pattern_locations")
  userNotes        String?  @map("user_notes")
  reviewed         Boolean  @default(false)
  reviewerNotes    String?  @map("reviewer_notes")
  reviewedAt       DateTime? @map("reviewed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([reviewed])
  @@index([createdAt])
  @@map("error_submissions")
}

model RateLimit {
  id         String   @id @default(cuid())
  ipHash     String   @unique @map("ip_hash")
  count      Int      @default(0)
  windowStart DateTime @map("window_start")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("rate_limits")
}
